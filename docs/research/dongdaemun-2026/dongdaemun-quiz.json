{
  "title": "\u97d3\u570b\u6642\u5c1a \u6e2c\u9a57",
  "questions": [
    {
      "question": "\u5728\u6771\u5927\u9580\u6279\u767c\u5e02\u5834\u4e2d\uff0c\u82e5\u60a8\u7684\u96fb\u5546\u5b9a\u4f4d\u70ba\u300c\u4e2d\u9ad8\u968e\u97d3\u7cfb\u5973\u88dd\u300d\uff0c\u6839\u64da\u8cc7\u6599\u5efa\u8b70\uff0c\u54ea\u4e00\u500b\u5546\u5834\u6700\u7b26\u5408\u60a8\u7684\u63a1\u8cfc\u9700\u6c42\uff1f",
      "answerOptions": [
        {
          "text": "The OT",
          "isCorrect": false,
          "rationale": "\u8a72\u5546\u5834\u4e3b\u8981\u4ee5\u5e73\u50f9\u4e14\u591a\u6a23\u5316\u7684\u6d41\u884c\u5973\u88dd\u70ba\u4e3b\uff0c\u9069\u5408\u983b\u7e41\u66f4\u65b0\u5eab\u5b58\u7684\u96f6\u552e\u5546\uff0c\u800c\u975e\u4e2d\u9ad8\u968e\u5b9a\u4f4d\u3002"
        },
        {
          "text": "DDP Fashion Mall (\u539f U:US)",
          "isCorrect": true,
          "rationale": "\u6b64\u5546\u5834\u5c08\u653b\u4e2d\u9ad8\u968e\u5973\u88dd\uff0c\u64c1\u6709\u8a31\u591a\u97d3\u570b\u672c\u571f\u54c1\u724c\uff0c\u4e26\u4ee5\u9ad8\u54c1\u8cea\u548c\u8da8\u52e2\u8a2d\u8a08\u8457\u7a31\u3002"
        },
        {
          "text": "Namdaemun Market (\u5357\u5927\u9580\u5e02\u5834)",
          "isCorrect": false,
          "rationale": "\u96d6\u7136\u5176\u6b77\u53f2\u60a0\u4e45\uff0c\u4f46\u63a1\u8cfc\u91cd\u9ede\u5728\u65bc\u7ae5\u88dd\u3001\u6587\u5275\u5546\u54c1\u53ca\u5bb6\u5ead\u7528\u54c1\uff0c\u800c\u975e\u5c08\u696d\u7684\u4e2d\u9ad8\u968e\u6642\u5c1a\u5973\u88dd\u3002"
        },
        {
          "text": "Coupang",
          "isCorrect": false,
          "rationale": "\u9019\u662f\u4e00\u500b\u5927\u578b\u96fb\u5b50\u5546\u52d9\u5e73\u53f0\uff0c\u96d6\u7136\u63d0\u4f9b\u6279\u767c\u670d\u52d9\uff0c\u4f46\u5176\u7522\u54c1\u7bc4\u570d\u6db5\u84cb\u5bb6\u96fb\u8207\u65e5\u7528\u54c1\uff0c\u4e0d\u5177\u5099\u6771\u5927\u9580\u5be6\u9ad4\u5546\u5834\u7684\u54c1\u724c\u8a2d\u8a08\u7279\u9ede\u3002"
        }
      ],
      "hint": "\u8acb\u56de\u60f3\u54ea\u4e00\u500b\u5546\u5834\u4ee5\u64c1\u6709\u8a31\u591a\u97d3\u570b\u672c\u571f\u8a2d\u8a08\u54c1\u724c\u53ca\u9ad8\u54c1\u8cea\u8457\u7a31\u3002"
    },
    {
      "question": "\u4f7f\u7528 Sinsang Market (\u65b0\u5546\u5e02\u5834) \u9032\u884c\u6578\u4f4d\u5316\u63a1\u8cfc\u6642\uff0c\u5176\u91dd\u5c0d\u300c\u7455\u75b5\u54c1\u300d\u63d0\u4f9b\u7684\u4fdd\u969c\u653f\u7b56\u70ba\u4f55\uff1f",
      "answerOptions": [
        {
          "text": "\u8cb7\u5bb6\u9700\u652f\u4ed8\u9000\u8ca8\u904b\u8cbb\u65b9\u53ef\u66f4\u63db",
          "isCorrect": false,
          "rationale": "\u8a72\u5e73\u53f0\u5f37\u8abf\u7121\u9700\u9000\u56de\u7455\u75b5\u54c1\u5373\u53ef\u7372\u5f97\u88dc\u767c\uff0c\u4ee5\u964d\u4f4e\u570b\u969b\u63a1\u8cfc\u7684\u98a8\u96aa\u8207\u4e0d\u4fbf\u3002"
        },
        {
          "text": "\u7455\u75b5\u54c1\u9700\u9000\u56de\u97d3\u570b\u7e3d\u90e8\u9451\u5b9a\u5f8c\u624d\u53ef\u9000\u6b3e",
          "isCorrect": false,
          "rationale": "\u6b64\u6d41\u7a0b\u904e\u65bc\u5197\u9577\u4e14\u4e0d\u7b26\u5408\u5e73\u53f0\u63d0\u5230\u7684\u300c\u7acb\u5373\u88dc\u9001\u66ff\u4ee3\u54c1\u300d\u653f\u7b56\u3002"
        },
        {
          "text": "\u76f4\u63a5\u767c\u9001\u66ff\u63db\u7522\u54c1\u4e14\u4e0d\u8981\u6c42\u9000\u56de\u7455\u75b5\u54c1",
          "isCorrect": true,
          "rationale": "\u70ba\u4e86\u8b93\u570b\u969b\u8cb7\u5bb6\u5b89\u5fc3\uff0c\u5e73\u53f0\u8ca0\u8cac\u6aa2\u9a57\u4e26\u627f\u8afe\u82e5\u6536\u5230\u7455\u75b5\u54c1\u6703\u7acb\u5373\u66f4\u63db\uff0c\u4e14\u7121\u9700\u8cb7\u5bb6\u9000\u56de\u3002"
        },
        {
          "text": "\u5e73\u53f0\u50c5\u63d0\u4f9b\u8cfc\u7269\u91d1\u88dc\u511f\uff0c\u4e0d\u88dc\u767c\u5be6\u7269",
          "isCorrect": false,
          "rationale": "\u96d6\u7136\u8cfc\u7269\u91d1\u662f\u5e38\u898b\u505a\u6cd5\uff0c\u4f46\u8cc7\u6599\u660e\u78ba\u6307\u51fa\u5e73\u53f0\u6703\u767c\u9001\u66f4\u63db\u7522\u54c1\u3002"
        }
      ],
      "hint": "\u95dc\u9375\u5728\u65bc\u570b\u969b\u63a1\u8cfc\u4e2d\uff0c\u8655\u7406\u9000\u56de\u6d41\u7a0b\u7684\u4fbf\u5229\u6027\u3002"
    },
    {
      "question": "\u6839\u64da McKinsey \u7684\u7814\u7a76\uff0c\u5f15\u5165 AI \u9a45\u52d5\u7684\u5eab\u5b58\u9810\u6e2c\u7cfb\u7d71\uff0c\u76f8\u8f03\u65bc\u50b3\u7d71\u65b9\u6cd5\uff0c\u9810\u6e2c\u8aa4\u5dee\u901a\u5e38\u80fd\u964d\u4f4e\u591a\u5c11\uff1f",
      "answerOptions": [
        {
          "text": "$10\\% - 15\\%$",
          "isCorrect": false,
          "rationale": "\u9019\u500b\u6bd4\u4f8b\u8f03\u63a5\u8fd1 AI \u5c0d\u5ba2\u6236\u6eff\u610f\u5ea6\u7684\u63d0\u5347\u6578\u503c\uff0c\u800c\u975e\u9810\u6e2c\u8aa4\u5dee\u7684\u964d\u4f4e\u5e45\u5ea6\u3002"
        },
        {
          "text": "$20\\% - 50\\%$",
          "isCorrect": true,
          "rationale": "\u7814\u7a76\u6307\u51fa AI \u9a45\u52d5\u7684\u9810\u6e2c\u80fd\u8655\u7406\u591a\u6e90\u6578\u64da\uff0c\u986f\u8457\u5c07\u8aa4\u5dee\u7387\u964d\u4f4e\u81f3\u50b3\u7d71\u65b9\u6cd5\u7684\u4e94\u6210\u81f3\u516b\u6210\u6c34\u5e73\u3002"
        },
        {
          "text": "$60\\% - 80\\%$",
          "isCorrect": false,
          "rationale": "\u96d6\u7136 AI \u6548\u679c\u986f\u8457\uff0c\u4f46\u76ee\u524d\u6280\u8853\u5c1a\u672a\u80fd\u5728\u591a\u8b8a\u7684\u5e02\u5834\u4e2d\u9054\u5230\u5982\u6b64\u6975\u9ad8\u6bd4\u4f8b\u7684\u5168\u9762\u8aa4\u5dee\u6d88\u9664\u3002"
        },
        {
          "text": "$5\\% - 10\\%$",
          "isCorrect": false,
          "rationale": "\u9019\u50c5\u662f\u521d\u6b65\u81ea\u52d5\u5316\u7684\u6548\u679c\uff0c\u672a\u80fd\u5c55\u73fe AI \u6a5f\u5668\u5b78\u7fd2\u8655\u7406\u5927\u91cf\u8b8a\u6578\u6642\u7684\u771f\u6b63\u6f5b\u529b\u3002"
        }
      ],
      "hint": "AI \u5728\u6578\u64da\u5206\u6790\u4e0a\u7684\u7cbe\u78ba\u5ea6\u80fd\u5927\u5e45\u63d0\u5347\uff0c\u8aa4\u5dee\u964d\u4f4e\u5e45\u5ea6\u901a\u5e38\u9054\u5230\u5169\u6210\u4ee5\u4e0a\u3002"
    },
    {
      "question": "\u9762\u5c0d\u4e2d\u570b\u8d85\u4f4e\u50f9\u96fb\u5546\u5e73\u53f0\uff08\u5982 AliExpress\u3001Temu\u3001Shein\uff09\u7684\u7af6\u722d\uff0c2026 \u5e74\u6771\u5927\u9580\u63a1\u53d6\u7684\u95dc\u9375\u5dee\u7570\u5316\u7b56\u7565\u70ba\u4f55\uff1f",
      "answerOptions": [
        {
          "text": "\u5168\u9762\u964d\u4f4e\u751f\u7522\u6210\u672c\u4ee5\u9032\u884c\u50f9\u683c\u6230",
          "isCorrect": false,
          "rationale": "\u9762\u5c0d\u5ee3\u5dde\u8d85\u4f4e\u50f9\u6a21\u5f0f\uff0c\u50f9\u683c\u6230\u4e26\u975e\u6771\u5927\u9580\u512a\u52e2\uff0c\u5176\u91cd\u9ede\u5df2\u8f49\u5411\u6587\u5316\u6ea2\u50f9\u8207\u54c1\u8cea\u3002"
        },
        {
          "text": "\u8f49\u578b\u70ba\u5b8c\u5168\u7684 B2C \u96f6\u552e\u6a21\u5f0f\u4e26\u653e\u68c4\u6279\u767c",
          "isCorrect": false,
          "rationale": "\u6a21\u5f0f\u662f\u7d50\u69cb\u6027\u8f49\u8b8a\u70ba B2B2C \u8207 D2C \u4e26\u91cd\uff0c\u800c\u975e\u653e\u68c4\u6279\u767c\u6839\u57fa\u3002"
        },
        {
          "text": "\u5f37\u8abf\u300c\u97d3\u570b\u88fd\u9020\u300d\u7684\u8a2d\u8a08\u512a\u8d8a\u6027\u8207\u4fe1\u4efb\u611f",
          "isCorrect": true,
          "rationale": "\u5206\u6790\u6307\u51fa\u900f\u904e\u54c1\u8cea\u5316\u5dee\u7570\u3001\u6578\u64da\u9a45\u52d5\u7684\u7b56\u5c55\u53ca K-fashion \u7684\u54c1\u724c\u50f9\u503c\u4f86\u5c0d\u6297\u4f4e\u50f9\u7af6\u722d\u3002"
        },
        {
          "text": "\u589e\u52a0\u5728\u5ee3\u5dde\u7684\u4ee3\u5de5\u6bd4\u4f8b\u4ee5\u964d\u4f4e\u552e\u50f9",
          "isCorrect": false,
          "rationale": "\u9019\u6703\u640d\u5bb3\u300c\u97d3\u570b\u88fd\u9020\u300d\u7684\u54c1\u724c\u529b\uff0c\u8207\u8cc7\u6599\u4e2d\u5f37\u8abf\u7684\u54c1\u8cea\u4e2d\u5fc3\u5316\u6230\u7565\u76f8\u5de6\u3002"
        }
      ],
      "hint": "\u601d\u8003\u9664\u4e86\u50f9\u683c\u4ee5\u5916\uff0c\u6d88\u8cbb\u8005\u9078\u64c7\u97d3\u570b\u6642\u5c1a\u7684\u6838\u5fc3\u52d5\u529b\u662f\u4ec0\u9ebc\u3002"
    },
    {
      "question": "\u82e5\u53f0\u7063\u884c\u92b7\u4eba\u54e1\u60f3\u8981\u5229\u7528 AI \u5de5\u5177\u512a\u5316\u73fe\u6709\u7684\u5eab\u5b58\u7ba1\u7406\uff0c\u4e0b\u5217\u54ea\u4e00\u9805\u300c\u975e\u300dAI \u5728\u8a72\u9818\u57df\u7684\u4e3b\u8981\u61c9\u7528\u6848\u4f8b\uff1f",
      "answerOptions": [
        {
          "text": "\u6839\u64da\u793e\u4ea4\u5a92\u9ad4\u8da8\u52e2\u9810\u6e2c\u9700\u6c42\u9ad8\u5cf0",
          "isCorrect": false,
          "rationale": "AI \u6a21\u578b\u80fd\u8655\u7406\u793e\u4ea4\u5a92\u9ad4\u7b49\u591a\u6e90\u6578\u64da\uff0c\u7cbe\u6e96\u9810\u6e2c\u672a\u4f86\u53ef\u80fd\u7684\u7206\u6b3e\u8207\u9700\u6c42\u3002"
        },
        {
          "text": "\u5728\u5eab\u5b58\u904e\u591a\u6642\u52d5\u52d5\u614b\u8abf\u6574\u6298\u6263\u8207\u4fc3\u92b7",
          "isCorrect": false,
          "rationale": "AI \u53ef\u6839\u64da\u5eab\u5b58\u6c34\u5e73\u8207\u5e02\u5834\u9700\u6c42\u5373\u6642\u8abf\u6574\u50f9\u683c\u7b56\u7565\uff0c\u5354\u52a9\u6e05\u7406\u5eab\u5b58\u3002"
        },
        {
          "text": "\u81ea\u52d5\u751f\u6210\u7522\u54c1\u7684 3D \u6578\u4f4d\u8a66\u7a7f\u5716\u50cf",
          "isCorrect": true,
          "rationale": "\u96d6\u7136\u9019\u8207 AI \u76f8\u95dc\uff0c\u4f46\u5b83\u5c6c\u65bc\u7522\u54c1\u5448\u73fe\u6216\u71df\u92b7\u7bc4\u7587\uff0c\u800c\u975e\u5eab\u5b58\u9810\u6e2c\u6216\u512a\u5316\u7684\u76f4\u63a5\u529f\u80fd\u3002"
        },
        {
          "text": "\u5075\u6e2c\u5eab\u5b58\u7d00\u9304\u8207\u5be6\u969b\u6578\u91cf\u7684\u7570\u5e38\u843d\u5dee\u4ee5\u9632\u76dc",
          "isCorrect": false,
          "rationale": "\u8a50\u9a19\u8207\u7570\u5e38\u6aa2\u6e2c\u662f AI \u5728\u5eab\u5b58\u7ba1\u7406\u4e2d\u7528\u65bc\u8b58\u5225\u5931\u7aca\u6216\u7cfb\u7d71\u6545\u969c\u7684\u91cd\u8981\u529f\u80fd\u3002"
        }
      ],
      "hint": "\u5eab\u5b58\u7ba1\u7406\u7684\u6838\u5fc3\u5728\u65bc\u6578\u91cf\u7684\u7cbe\u6e96\u63a7\u5236\u8207\u6d41\u7a0b\u7684\u81ea\u52d5\u5316\u88dc\u8ca8\u3002"
    },
    {
      "question": "\u5c0d\u65bc\u300c\u521d\u5275\u300d\u4e14\u300c\u7121\u5be6\u9ad4\u5e97\u9762\u300d\u7684\u96fb\u5546\uff0cSinsang Market \u7684\u54ea\u4e00\u9805\u7279\u9ede\u6700\u80fd\u5e6b\u52a9\u6e1b\u5c11\u521d\u671f\u8cc7\u91d1\u58d3\u529b\uff1f",
      "answerOptions": [
        {
          "text": "\u63d0\u4f9b\u7121\u9650\u5236\u7684\u514d\u904b\u8cbb\u670d\u52d9",
          "isCorrect": false,
          "rationale": "\u904b\u8cbb\u4ecd\u7531\u8cb7\u5bb6\u8ca0\u64d4\u6216\u9700\u806f\u7e6b\u5ba2\u670d\u4e86\u89e3\uff0c\u4e26\u975e\u6e1b\u8f15\u8cc7\u91d1\u58d3\u529b\u7684\u4e3b\u56e0\u3002"
        },
        {
          "text": "\u7121\u9700\u56e4\u8ca8\u5eab\u5b58\uff0c\u6975\u5c0f\u5316\u6295\u8cc7\u98a8\u96aa",
          "isCorrect": true,
          "rationale": "\u900f\u904e\u9060\u7aef\u63a1\u8cfc\u8207\u76f4\u767c\u7cfb\u7d71\uff0c\u96f6\u552e\u5546\u7121\u9700\u5728\u92b7\u552e\u524d\u6301\u6709\u5927\u91cf\u5be6\u9ad4\u5eab\u5b58\u3002"
        },
        {
          "text": "\u63d0\u4f9b\u9577\u671f\u7121\u606f\u8cb8\u6b3e\u7d66\u96f6\u552e\u5546",
          "isCorrect": false,
          "rationale": "\u8cc7\u6599\u4e2d\u4e26\u672a\u63d0\u5230\u5e73\u53f0\u63d0\u4f9b\u91d1\u878d\u501f\u8cb8\u6216\u7121\u606f\u8cb8\u6b3e\u529f\u80fd\u3002"
        },
        {
          "text": "\u4fdd\u8b49\u6240\u6709\u5546\u54c1\u5229\u6f64\u7387\u9054\u5230 $50\\%$ \u4ee5\u4e0a",
          "isCorrect": false,
          "rationale": "\u5229\u6f64\u7387\u53d6\u6c7a\u65bc\u96f6\u552e\u5546\u7684\u5b9a\u50f9\u7b56\u7565\uff0c\u5e73\u53f0\u4e26\u4e0d\u4fdd\u8b49\u6700\u7d42\u7372\u5229\u6578\u5b57\u3002"
        }
      ],
      "hint": "\u8003\u616e\u300c\u8f15\u8cc7\u7522\u300d\u904b\u71df\u6a21\u5f0f\u5982\u4f55\u964d\u4f4e\u8d77\u6b65\u9580\u6abb\u3002"
    },
    {
      "question": "\u89aa\u81ea\u524d\u5f80\u6771\u5927\u9580\u5e02\u5834\u63a1\u8cfc\u6642\uff0c\u5c0d\u65bc\u300c\u4ed8\u6b3e\u65b9\u5f0f\u300d\u7684\u63cf\u8ff0\uff0c\u4e0b\u5217\u4f55\u8005\u6b63\u78ba\uff1f",
      "answerOptions": [
        {
          "text": "\u6240\u6709\u5546\u92ea\u7686\u652f\u6301\u570b\u969b\u4fe1\u7528\u5361\u5237\u5361",
          "isCorrect": false,
          "rationale": "\u8cc7\u6599\u660e\u78ba\u6307\u51fa\u5927\u591a\u6578\u6279\u767c\u5546\u50c5\u63a5\u53d7\u73fe\u91d1\u652f\u4ed8\uff0c\u5237\u5361\u4e26\u4e0d\u666e\u904d\u3002"
        },
        {
          "text": "\u5927\u591a\u6578\u6279\u767c\u5546\u50c5\u63a5\u53d7\u73fe\u91d1\uff0c\u4e26\u63d0\u4f9b\u6536\u64da\u4ee5\u4f9b\u53d6\u8ca8",
          "isCorrect": true,
          "rationale": "\u6279\u767c\u5e02\u5834\u901a\u5e38\u4ee5\u73fe\u91d1\u4ea4\u6613\u70ba\u4e3b\uff0c\u6536\u64da\u662f\u5f8c\u7e8c\u5411\u5e02\u5834\u5916\u7269\u6d41\u5e97\u53d6\u8ca8\u7684\u6191\u8b49\u3002"
        },
        {
          "text": "\u53ef\u4f7f\u7528\u96fb\u5b50\u5546\u52d9\u5e33\u865f\u9032\u884c\u6383\u78bc\u5ef6\u5f8c\u4ed8\u6b3e",
          "isCorrect": false,
          "rationale": "\u9019\u985e\u91d1\u878d\u6280\u8853\u5728\u50b3\u7d71\u6771\u5927\u9580\u591c\u9593\u6279\u767c\u5e02\u5834\u4e26\u975e\u4e3b\u6d41\u4ed8\u6b3e\u65b9\u5f0f\u3002"
        },
        {
          "text": "\u50c5\u63a5\u53d7\u97d3\u5e63\u73fe\u91d1\uff0c\u4e0d\u63a5\u53d7\u4efb\u4f55\u5916\u5e63\u6216\u652f\u7968",
          "isCorrect": false,
          "rationale": "\u96d6\u7136\u73fe\u91d1\u70ba\u4e3b\uff0c\u4f46\u8cc7\u6599\u91cd\u9ede\u5728\u65bc\u300c\u73fe\u91d1\u4ea4\u6613\u300d\u76f8\u5c0d\u65bc\u96fb\u5b50\u7684\u6392\u4ed6\u6027\uff0c\u672a\u8a73\u5217\u5916\u5e63\u7d30\u7bc0\u3002"
        }
      ],
      "hint": "\u9019\u662f\u4e00\u500b\u591c\u9593\u904b\u4f5c\u7684\u50b3\u7d71\u6279\u767c\u74b0\u5883\uff0c\u4ea4\u6613\u65b9\u5f0f\u76f8\u5c0d\u76f4\u63a5\u4e14\u5be6\u9ad4\u3002"
    },
    {
      "question": "Sinsang Market \u65d7\u4e0b\u7684 Sinsang Studio \u63d0\u4f9b\u4ec0\u9ebc\u6a23\u7684\u4e00\u7ad9\u5f0f\u670d\u52d9\uff1f",
      "answerOptions": [
        {
          "text": "\u63d0\u4f9b\u96f6\u552e\u5546\u76f4\u64ad\u5e36\u8ca8\u7684\u651d\u5f71\u68da\u79df\u501f",
          "isCorrect": false,
          "rationale": "\u8a72\u670d\u52d9\u76ee\u524d\u7684\u63cf\u8ff0\u6838\u5fc3\u5728\u65bc\u70ba\u6279\u767c\u5546\u62cd\u651d\u7522\u54c1\u7167\u4e26\u4e0a\u50b3\u5e73\u53f0\u3002"
        },
        {
          "text": "\u4ee3\u6279\u767c\u5546\u53d6\u8ca8\u3001\u62cd\u651d\u4e26\u4e0a\u50b3\u5e73\u53f0\uff0c\u6700\u5f8c\u6b78\u9084\u5546\u54c1",
          "isCorrect": true,
          "rationale": "\u9019\u662f\u4e00\u500b\u91dd\u5c0d\u6279\u767c\u5546\u7684\u5167\u5bb9\u7522\u51fa\u670d\u52d9\uff0c\u4e00\u9031\u5167\u5373\u53ef\u5b8c\u6210\u62cd\u651d\u8207\u4e0a\u50b3\uff0c\u6975\u5927\u5316\u66dd\u5149\u6548\u7387\u3002"
        },
        {
          "text": "\u70ba\u96f6\u552e\u5546\u63d0\u4f9b AI \u63db\u81c9\u6a21\u7279\u5152\u5408\u6210\u6280\u8853",
          "isCorrect": false,
          "rationale": "\u8cc7\u6599\u4e2d\u63d0\u5230\u7684 Sinsang Studio \u4ecd\u662f\u4ee5\u5be6\u9ad4\u62cd\u651d\u6d41\u7a0b\u70ba\u4e3b\u3002"
        },
        {
          "text": "\u63d0\u4f9b\u8de8\u5883\u7269\u6d41\u7684\u5305\u88dd\u8207\u6253\u6a19\u670d\u52d9",
          "isCorrect": false,
          "rationale": "\u7269\u6d41\u8207\u5305\u88dd\u5c6c\u65bc Sinsang Delivery \u6216\u5916\u90e8\u7269\u6d41\u5546\uff0c\u800c\u975e Studio \u651d\u5f71\u670d\u52d9\u3002"
        }
      ],
      "hint": "\u9019\u9805\u670d\u52d9\u65e8\u5728\u89e3\u6c7a\u6279\u767c\u5546\u7f3a\u4e4f\u5c08\u696d\u5546\u54c1\u5716\u7684\u554f\u984c\u3002"
    },
    {
      "question": "\u5728 AI \u8f49\u578b (AX) \u80cc\u666f\u4e0b\uff0c2026 \u5e74\u9996\u723e\u5e02\u653f\u5e9c\u5c0d\u6771\u5927\u9580\u5f9e\u696d\u4eba\u54e1\u63d0\u4f9b\u7684\u57f9\u8a13\u91cd\u9ede\u5305\u542b\u4ec0\u9ebc\uff1f",
      "answerOptions": [
        {
          "text": "\u50b3\u7d71\u7d21\u7e54\u6280\u8853\u7684\u50b3\u627f\u8207\u4fee\u88dc",
          "isCorrect": false,
          "rationale": "\u96d6\u7136\u6280\u8853\u91cd\u8981\uff0c\u4f46\u653f\u7b56\u73fe\u968e\u6bb5\u91cd\u9ede\u5728\u65bc\u56e0\u61c9\u6578\u4f4d\u5316\u6311\u6230\u7684 AI \u6280\u8853\u3002"
        },
        {
          "text": "AI \u5167\u5bb9\u88fd\u4f5c\u3001\u884c\u92b7\u53ca 3D \u6578\u4f4d\u6642\u5c1a\u5c08\u5bb6\u57f9\u8a13",
          "isCorrect": true,
          "rationale": "\u9019\u662f\u300c2026 AI \u6642\u5c1a\u5be6\u8e10\u80fd\u529b\u6559\u80b2\u300d\u7684\u6838\u5fc3\uff0c\u65e8\u5728\u63d0\u5347\u6771\u5927\u9580\u7684\u54c1\u724c\u7af6\u722d\u529b\u8207\u6578\u4f4d\u6230\u9b25\u529b\u3002"
        },
        {
          "text": "\u57fa\u790e\u7684\u82f1\u6587\u8207\u65e5\u6587\u570b\u969b\u8cbf\u6613\u5c0d\u8a71",
          "isCorrect": false,
          "rationale": "\u5916\u8a9e\u662f\u57fa\u790e\uff0c\u4f46\u653f\u5e9c\u91cd\u9ede\u63a8\u52d5\u7684\u662f\u66f4\u5177\u6280\u8853\u9580\u6abb\u7684 AI \u8207 3D \u6578\u4f4d\u8a2d\u8a08\u61c9\u7528\u3002"
        },
        {
          "text": "\u7dda\u4e0b\u5be6\u9ad4\u5e97\u92ea\u7684\u88dd\u6f62\u8207\u8996\u89ba\u8a2d\u8a08",
          "isCorrect": false,
          "rationale": "\u76ee\u524d\u7684\u653f\u7b56\u5c0e\u5411\u66f4\u504f\u5411\u65bc\u300c\u6578\u4f4d\u5148\u9a45\u300d\u8207\u300c\u5168\u7403\u5e73\u53f0\u300d\u8f49\u578b\u3002"
        }
      ],
      "hint": "\u95dc\u6ce8\u653f\u7b56\u5982\u4f55\u5e6b\u52a9\u50b3\u7d71\u5e02\u5834\u61c9\u5c0d\u300c\u6578\u4f4d\u6d77\u562f\u300d\u3002"
    },
    {
      "question": "Zara \u5229\u7528 AI \u6280\u8853\u5be6\u73fe\u300c\u5feb\u901f\u88dc\u8ca8\u300d\u7684\u539f\u7406\u4e3b\u8981\u662f\u5206\u6790\u4e0b\u5217\u54ea\u7a2e\u6578\u64da\uff1f",
      "answerOptions": [
        {
          "text": "\u5168\u7403\u5929\u6c23\u8b8a\u9077\u9810\u6e2c\u6578\u64da",
          "isCorrect": false,
          "rationale": "\u96d6\u7136\u5929\u6c23\u5f71\u97ff\u5eab\u5b58\uff0c\u4f46\u5feb\u901f\u88dc\u8ca8\u6700\u6838\u5fc3\u7684\u4f9d\u64da\u662f\u5be6\u6642\u92b7\u552e\u72c0\u6cc1\u8207\u8da8\u52e2\u3002"
        },
        {
          "text": "\u92b7\u552e\u6578\u64da\u8207\u9810\u6e2c\u8da8\u52e2\uff0c\u907f\u514d\u7f3a\u8ca8\u6216\u7a4d\u58d3",
          "isCorrect": true,
          "rationale": "AI \u4ee3\u7406\u80fd\u5206\u6790\u92b7\u552e\u6578\u64da\u4ee5\u7cbe\u6e96\u9810\u6e2c\u54ea\u4e9b\u6b3e\u5f0f\u53d7\u6b61\u8fce\uff0c\u5f9e\u800c\u5be6\u73fe\u5373\u6642\u88dc\u8ca8\u4e26\u964d\u4f4e\u5eab\u5b58\u98a8\u96aa\u3002"
        },
        {
          "text": "\u5404\u570b\u653f\u5e9c\u7684\u95dc\u7a05\u8207\u8cbf\u6613\u653f\u7b56",
          "isCorrect": false,
          "rationale": "\u9019\u662f\u98a8\u96aa\u7de9\u91cb\u7b56\u7565\uff08\u5982 Toyota \u7684\u6848\u4f8b\uff09\uff0c\u800c\u975e\u5feb\u901f\u6642\u5c1a\u65e5\u5e38\u88dc\u8ca8\u7684\u4e3b\u8981\u9a45\u52d5\u529b\u3002"
        },
        {
          "text": "\u5de5\u5ee0\u52de\u52d5\u529b\u7684\u5373\u6642\u751f\u7522\u6210\u672c",
          "isCorrect": false,
          "rationale": "\u6210\u672c\u96d6\u7136\u91cd\u8981\uff0c\u4f46\u88dc\u8ca8\u6c7a\u7b56\u66f4\u5f37\u8abf\u300c\u5e02\u5834\u53cd\u61c9\u901f\u5ea6\u300d\u3002"
        }
      ],
      "hint": "\u5feb\u901f\u6642\u5c1a\u6210\u529f\u7684\u95dc\u9375\u5728\u65bc\u300c\u6578\u64da\u56de\u994b\u300d\u7684\u53ca\u6642\u6027\u3002"
    },
    {
      "question": "\u96fb\u5546\u884c\u92b7\u4eba\u54e1\u5728\u898f\u756b\u300c\u53f0\u7063\u5e02\u5834\u53ef\u57f7\u884c\u7b56\u7565\u300d\u6642\uff0c\u70ba\u4f55\u61c9\u8003\u616e\u5f15\u5165\u300c\u6578\u4f4d\u63a1\u8cfc\u7cbe\u901a\u300d (Digital Sourcing Mastery)\uff1f",
      "answerOptions": [
        {
          "text": "\u56e0\u70ba\u5be6\u9ad4\u6771\u5927\u9580\u5e02\u5834\u5373\u5c07\u5728 2026 \u5e74\u5b8c\u5168\u62c6\u9664",
          "isCorrect": false,
          "rationale": "\u6771\u5927\u9580\u4e26\u975e\u62c6\u9664\uff0c\u800c\u662f\u8f49\u578b\u70ba\u6578\u4f4d\u8207\u5be6\u9ad4\u6df7\u5408\u7684\u5e73\u53f0\u3002"
        },
        {
          "text": "\u900f\u904e\u5782\u76f4\u5e73\u53f0\u8207\u9060\u7aef\u63a1\u8cfc App \u6700\u5c0f\u5316\u5eab\u5b58\u98a8\u96aa",
          "isCorrect": true,
          "rationale": "\u9019\u80fd\u8b93\u96f6\u552e\u5546\u66f4\u9748\u6d3b\u5730\u61c9\u5c0d\u5e02\u5834\u8b8a\u5316\uff0c\u4e26\u6700\u5927\u5316\u6771\u5927\u9580\u7368\u7279\u4f9b\u61c9\u93c8\u7684\u89f8\u53ca\u7387\u3002"
        },
        {
          "text": "\u56e0\u70ba\u97d3\u570b\u653f\u5e9c\u898f\u5b9a\u5916\u570b\u8cb7\u5bb6\u50c5\u80fd\u900f\u904e App \u63a1\u8cfc",
          "isCorrect": false,
          "rationale": "\u76ee\u524d\u4ecd\u652f\u6301\u7dda\u4e0b\u5be6\u9ad4\u63a1\u8cfc\uff0c\u4e26\u6c92\u6709\u5f37\u5236\u6027\u7684\u6392\u4ed6\u898f\u5b9a\u3002"
        },
        {
          "text": "\u6578\u4f4d\u63a1\u8cfc\u80fd\u81ea\u52d5\u514d\u9664\u6240\u6709\u7684\u9032\u53e3\u6d77\u95dc\u7533\u5831\u624b\u7e8c",
          "isCorrect": false,
          "rationale": "\u96d6\u7136\u5e73\u53f0\u6703\u4ee3\u70ba\u8655\u7406\u90e8\u5206\u624b\u7e8c\uff0c\u4f46\u300c\u7cbe\u901a\u6578\u4f4d\u63a1\u8cfc\u300d\u7684\u6230\u7565\u610f\u6db5\u66f4\u5ee3\uff0c\u5728\u65bc\u9748\u6d3b\u6027\u8207\u89f8\u53ca\u9762\u3002"
        }
      ],
      "hint": "\u9019\u8207\u96fb\u5546\u5982\u4f55\u5728\u5168\u7403\u5316\u7af6\u722d\u4e2d\u4fdd\u6301\u300c\u654f\u6377\u6027\u300d\u6709\u95dc\u3002"
    }
  ]
}