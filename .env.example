# ==========================================================
# CHIC KIM & MIU｜靚秀國際有限公司 環境變數範例
# ----------------------------------------------------------
# 複製本檔為 .env 後填入實際值。.env 絕對不要 commit。
# ==========================================================

# ========== Payload CMS ==========
# 至少 32 字元的隨機字串。可用 `openssl rand -base64 48` 生成
PAYLOAD_SECRET=REPLACE_ME_WITH_RANDOM_STRING

# 資料庫連線。Prod 實際使用 SQLite（見 memory: prod_hetzner_deployment）
# SQLite：file:./data/chickimmiu.db
# Postgres（選用）：postgresql://user:password@localhost:5432/chickimmiu
DATABASE_URI=file:./data/chickimmiu.db

# Admin reset password（僅 src/seed/resetAdmin.ts / queryAdmin.ts 會讀取）
# 執行前 export 一次，勿寫進 .env committed
ADMIN_RESET_PASSWORD=

# ========== 網站 ==========
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=CHIC KIM & MIU

# ========== NextAuth v5 (會在階段 2 啟用) ==========
AUTH_SECRET=REPLACE_ME_WITH_32_CHAR_RANDOM_STRING
AUTH_URL=http://localhost:3000

# --- 社群登入 ---
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

AUTH_FACEBOOK_ID=
AUTH_FACEBOOK_SECRET=

AUTH_LINE_CHANNEL_ID=
AUTH_LINE_CHANNEL_SECRET=

# ========== 金流 ==========
# PayPal — 在 https://developer.paypal.com 建立 App 取得
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENV=sandbox

# 綠界科技 ECPay
ECPAY_MERCHANT_ID=
ECPAY_HASH_KEY=
ECPAY_HASH_IV=
ECPAY_ENV=sandbox

# 藍新支付 NewebPay
NEWEBPAY_MERCHANT_ID=
NEWEBPAY_HASH_KEY=
NEWEBPAY_HASH_IV=

# LINE Pay
LINE_PAY_CHANNEL_ID=
LINE_PAY_CHANNEL_SECRET=
LINE_PAY_ENV=sandbox

# ========== 客服 (會在階段 4 啟用) ==========
# LINE Official Account
NEXT_PUBLIC_LINE_OA_ID=
# Meta Messenger Plugin
NEXT_PUBLIC_FB_PAGE_ID=

# ========== 廣告追蹤 (會在階段 6 啟用) ==========
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_META_PIXEL_ID=
META_CAPI_ACCESS_TOKEN=
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_GOOGLE_ADS_ID=

# ========== 雲端儲存（Cloudflare R2） ==========
# prod 使用 R2 做媒體 offsite backup。本機 dev 不需填。
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# ========== 排程 Cron（GitHub Actions 觸發） ==========
# 保護 /api/cron/* endpoints 的 Bearer token。請用 `openssl rand -base64 24` 生成。
# Prod 值需與 GitHub repo Settings → Secrets → CRON_SECRET 一致。
CRON_SECRET=REPLACE_ME_WITH_RANDOM_STRING
